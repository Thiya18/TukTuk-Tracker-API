{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-bc6d-e7f8g9h0i1j2",
		"name": "Tuk-Tuk Tracker API",
		"description": "Comprehensive test suite for Tuk-Tuk Tracker API (NIBM/Coventry University). Covers Auth, Vehicles, Tracking, and Admin scoping.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Token is present\", () => pm.expect(pm.response.json().token).to.be.a('string'));",
									"if(pm.response.to.have.status(200)) {",
									"    pm.environment.set(\"token\", pm.response.json().token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"hq_admin\",\n    \"password\": \"Admin@1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					},
					"response": []
				},
				{
					"name": "Get Profile (Me)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"User data returned\", () => pm.expect(pm.response.json().data.username).to.equal(\"hq_admin\"));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "me"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Vehicles",
			"item": [
				{
					"name": "Get All Vehicles (Paginated)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"ETag is present\", () => pm.expect(pm.response.headers.get('ETag')).to.exist);",
									"pm.test(\"Pagination data present\", () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.total).to.be.a('number');",
									"    pm.expect(json.page).to.be.a('number');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/vehicles?page=1&limit=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "vehicles"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					},
					"response": []
				},
				{
					"name": "Register New Vehicle",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
									"pm.test(\"Location header is present\", () => pm.expect(pm.response.headers.get('Location')).to.contain('/api/v1/vehicles/'));",
									"if(pm.response.to.have.status(201)) {",
									"    pm.environment.set(\"test_vehicle_id\", pm.response.json().data._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"registrationNumber\": \"WP-TEST-9999\",\n    \"district\": \"66236688e1a74d7568600001\",\n    \"province\": \"66236688e1a74d7568600000\",\n    \"status\": \"active\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/vehicles",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "vehicles"]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Tracking",
			"item": [
				{
					"name": "Submit GPS Ping",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 201\", () => pm.response.to.have.status(201));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"vehicleId\": \"{{test_vehicle_id}}\",\n    \"latitude\": 6.9271,\n    \"longitude\": 79.8612,\n    \"speed\": 35\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/locations",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "locations"]
						}
					},
					"response": []
				},
				{
					"name": "Get Location History (Paginated)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Pagination links work\", () => pm.expect(pm.response.json().pages).to.exist);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/locations/{{test_vehicle_id}}/history?page=1&limit=50",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "locations", "{{test_vehicle_id}}", "history"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "50" }
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Monitoring",
			"item": [
				{
					"name": "Health Check with Metrics",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Memory metrics present\", () => pm.expect(pm.response.json().memory).to.exist);",
									"pm.test(\"Uptime present\", () => pm.expect(pm.response.json().uptime).to.exist);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
